generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  username      String?       @unique
  password      String
  name          String?
  createdAt     DateTime      @default(now())

  // ─── Pro subscription fields (Stripe) ──────────────────────────────
  // TO PUBLISH: run `npx prisma migrate dev --name add-pro-fields`
  isPro                Boolean   @default(false)
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  proSince             DateTime?
  proCancelledAt       DateTime?
  // ───────────────────────────────────────────────────────────────────

  // ─── AI experience level ────────────────────────────────────────────
  experienceLevel      String    @default("beginner")
  // ───────────────────────────────────────────────────────────────────

  // ─── Onboarding ─────────────────────────────────────────────────────
  hasOnboarded         Boolean   @default(false)

  // ─── Email verification ──────────────────────────────────────────────
  emailVerified        Boolean   @default(false)
  // ───────────────────────────────────────────────────────────────────

  // ─── Activity tracking ──────────────────────────────────────────────
  lastActiveAt         DateTime?
  // ───────────────────────────────────────────────────────────────────

  holdings            Holding[]
  watchlistItems      WatchlistItem[]
  alerts              PriceAlert[]
  virtualPortfolio    VirtualPortfolio?
  virtualSeasonRecord VirtualSeasonRecord[]
  weeklyUserPicks     WeeklyUserPick[]
}

model Holding {
  id            String   @id @default(cuid())
  userId        String
  ticker        String
  companyName   String
  shares        Float
  purchasePrice Float
  purchaseDate  DateTime
  sector        String   @default("Unknown")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model WatchlistItem {
  id        String   @id @default(cuid())
  userId    String
  ticker    String
  addedAt   DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ticker])
  @@index([userId])
}

model PriceAlert {
  id          String   @id @default(cuid())
  userId      String
  ticker      String
  targetPrice Float
  condition   String   // "above" | "below"
  type        String   // "alert" | "stop_loss"
  note        String?
  triggered   Boolean  @default(false)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VirtualPortfolio {
  id               String           @id @default(cuid())
  userId           String           @unique
  cash             Float            @default(100000)
  totalValue       Float            @default(100000)
  season           Int              @default(1)
  resetAt          DateTime
  monthlyBaseline  Float            @default(100000)
  monthlyResetAt   DateTime         @default(now())
  createdAt        DateTime         @default(now())
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  holdings         VirtualHolding[]
  trades           VirtualTrade[]
}

model VirtualHolding {
  id          String           @id @default(cuid())
  portfolioId String
  ticker      String
  companyName String
  shares      Float
  avgCost     Float
  portfolio   VirtualPortfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, ticker])
}

model VirtualTrade {
  id          String           @id @default(cuid())
  portfolioId String
  ticker      String
  shares      Float
  price       Float
  type        String           // BUY | SELL
  executedAt  DateTime         @default(now())
  portfolio   VirtualPortfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
}

model HedgeFundCache {
  cik       String   @id
  name      String
  data      String   // JSON stringified fund data
  updatedAt DateTime @updatedAt
}

model SpikeSummaryCache {
  id        String   @id // "{TICKER}-{DATE}" e.g. "AAPL-2025-05-01"
  summary   String
  createdAt DateTime @default(now())
}

model FeatureFlag {
  key       String   @id
  enabled   Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

model OnboardingResponse {
  id         String   @id @default(cuid())
  experience String
  goals      String   // JSON array of goal ids
  createdAt  DateTime @default(now())
}

model WeeklyPickCache {
  weekKey   String   @id  // e.g. "2026-05-17"
  data      String        // JSON stringified pick
  createdAt DateTime @default(now())
}

model HotTakeCache {
  date      String   @id  // e.g. "2026-05-18"
  data      String        // JSON stringified hot take
  createdAt DateTime @default(now())
}

model VirtualSeasonRecord {
  id         String   @id @default(cuid())
  userId     String
  season     Int
  finalValue Float
  rank       Int?
  endedAt    DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, season])
}

model BullBearCache {
  id        String   @id  // "{TICKER}-{DATE}" e.g. "AAPL-2026-05-18"
  data      String        // JSON stringified BullVsBearResult
  createdAt DateTime @default(now())
}

model InsiderTradeCache {
  id        String   @id @default("singleton") // one row, always overwritten
  trades    String   // JSON stringified Trade[]
  updatedAt DateTime @updatedAt
}

model PageView {
  id    String @id @default(cuid())
  page  String // e.g. "/dashboard", "/research", "/chat"
  date  String // "YYYY-MM-DD"
  count Int    @default(1)

  @@unique([page, date])
  @@index([date])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

model AIAnalysisCache {
  id        String   @id  // "{TICKER}-{DATE}" e.g. "AAPL-2026-05-25"
  ticker    String
  date      String   // "YYYY-MM-DD" ET
  data      String   // JSON stringified ensemble result
  createdAt DateTime @default(now())

  @@index([ticker])
  @@index([date])
}

model MarketBriefCache {
  id        String   @id  // "{DATE}-{slot}" e.g. "2026-05-26-morning"
  slot      String        // "morning" | "midday"
  date      String        // "YYYY-MM-DD" ET
  data      String        // JSON stringified result
  createdAt DateTime @default(now())

  @@index([date])
}

model WeeklyUserPick {
  id          String   @id @default(cuid())
  userId      String
  weekKey     String   // e.g. "2026-05-25" (Sunday of that week)
  ticker      String
  companyName String
  entryPrice  Float
  direction   String   // "up" | "down"
  submittedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekKey])
  @@index([userId])
}

model DailyAIUsage {
  id      String @id @default(cuid())
  userId  String
  date    String // "YYYY-MM-DD"
  feature String @default("general") // e.g. "chat", "report-card", "spike-summary"
  count   Int    @default(0)

  @@unique([userId, date, feature])
  @@index([userId])
}
