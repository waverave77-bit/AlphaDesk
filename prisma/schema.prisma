generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  password      String
  name          String?
  createdAt     DateTime      @default(now())
  holdings            Holding[]
  watchlistItems      WatchlistItem[]
  alerts              PriceAlert[]
  virtualPortfolio    VirtualPortfolio?
  virtualSeasonRecord VirtualSeasonRecord[]
}

model Holding {
  id            String   @id @default(cuid())
  userId        String
  ticker        String
  companyName   String
  shares        Float
  purchasePrice Float
  purchaseDate  DateTime
  sector        String   @default("Unknown")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model WatchlistItem {
  id        String   @id @default(cuid())
  userId    String
  ticker    String
  addedAt   DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ticker])
  @@index([userId])
}

model PriceAlert {
  id          String   @id @default(cuid())
  userId      String
  ticker      String
  targetPrice Float
  condition   String   // "above" | "below"
  type        String   // "alert" | "stop_loss"
  note        String?
  triggered   Boolean  @default(false)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VirtualPortfolio {
  id         String           @id @default(cuid())
  userId     String           @unique
  cash       Float            @default(100000)
  totalValue Float            @default(100000)
  season     Int              @default(1)
  resetAt    DateTime
  createdAt  DateTime         @default(now())
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  holdings   VirtualHolding[]
  trades     VirtualTrade[]
}

model VirtualHolding {
  id          String           @id @default(cuid())
  portfolioId String
  ticker      String
  companyName String
  shares      Float
  avgCost     Float
  portfolio   VirtualPortfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, ticker])
}

model VirtualTrade {
  id          String           @id @default(cuid())
  portfolioId String
  ticker      String
  shares      Float
  price       Float
  type        String           // BUY | SELL
  executedAt  DateTime         @default(now())
  portfolio   VirtualPortfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
}

model HedgeFundCache {
  cik       String   @id
  name      String
  data      String   // JSON stringified fund data
  updatedAt DateTime @updatedAt
}

model FeatureFlag {
  key       String   @id
  enabled   Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

model OnboardingResponse {
  id         String   @id @default(cuid())
  experience String
  goals      String   // JSON array of goal ids
  createdAt  DateTime @default(now())
}

model VirtualSeasonRecord {
  id         String   @id @default(cuid())
  userId     String
  season     Int
  finalValue Float
  rank       Int?
  endedAt    DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, season])
}
